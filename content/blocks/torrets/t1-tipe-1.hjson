  coolant: {
    amount: 0.1
  }
}

drawer: { 
  type: DrawTurret 
  drawers: [ 
    { 
    type: DrawLiquidTile 
    drawLiquid: 
    coolant padding: 2 
    } 
    { 
    type: DrawTurret 
    parts: [ 
    { type: RegionPart 
    suffix: -top 
    progress: recoil 
    moveY: -1.5  
    } 
  ] 
} 
] 
}

